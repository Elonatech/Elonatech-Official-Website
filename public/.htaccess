<IfModule mod_rewrite.c>

  RewriteEngine On

  RewriteBase /

  RewriteRule ^index\.html$ - [L]

  # Redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.elonatech\.com\.ng [NC]
  RewriteRule ^(.*)$ https://elonatech.com.ng/$1 [R=301,L]

  # Redirect /services/ to homepage (page no longer exists)
  RewriteRule ^services/?$ / [R=301,L]

  # Conditions to check if the requested file, directory, or symbolic link does not exist
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l

  # If no file, directory, or symbolic link matches, serve index.html (React SPA fallback)
  RewriteRule . /index.html [L]

</IfModule>